<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base with subtle gradient -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#1F242F"
                android:endColor="#181D28"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Inner glow effect -->
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <stroke
                android:width="1dp"
                android:color="#14FFFFFF" />
            <corners android:radius="11dp" />
        </shape>
    </item>
</layer-list>
