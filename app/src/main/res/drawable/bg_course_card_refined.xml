<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow for elevation -->
    <item
        android:top="2dp"
        android:left="2dp">
        <shape>
            <solid android:color="#12000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Main card background -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#1F242E"
                android:endColor="#181C27"
                android:type="linear" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#2D3548" />
        </shape>
    </item>

    <!-- Subtle top highlight -->
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:height="1dp">
        <shape>
            <solid android:color="#1AFFFFFF" />
            <corners
                android:topLeftRadius="15dp"
                android:topRightRadius="15dp" />
        </shape>
    </item>
</layer-list>
