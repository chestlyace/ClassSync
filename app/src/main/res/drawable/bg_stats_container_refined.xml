<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer for depth -->
    <item
        android:top="2dp"
        android:left="2dp">
        <shape>
            <solid android:color="#0A000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Main background with subtle gradient -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#1A1F2E"
                android:endColor="#141923"
                android:type="linear" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#2D3548" />
        </shape>
    </item>

    <!-- Subtle inner highlight -->
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF" />
            <corners android:radius="19dp" />
        </shape>
    </item>
</layer-list>
