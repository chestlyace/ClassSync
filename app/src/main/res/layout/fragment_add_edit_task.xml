<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top AppBar -->
    <LinearLayout
        android:id="@+id/top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="1dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            android:src="@drawable/ic_close"
            app:tint="@color/on_surface_variant" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-bold"
            android:text="New Task"
            android:textColor="@color/on_surface"
            android:textSize="18sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="56dp"
        android:background="@color/outline_variant" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="57dp"
        android:paddingBottom="40dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Task Name Input Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="Task Name"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/input_task_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/selector_input_field"
                android:hint="e.g. Finish Synthesis Report"
                android:inputType="textCapSentences"
                android:paddingHorizontal="16dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline"
                android:textSize="16sp"
                android:maxLines="1"
                android:layout_marginBottom="24dp" />

            <!-- Assign To Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Assign to"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btn_add_member"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Add Member"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Horizontal Member Avatars -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="4dp">

                    <!-- Member 1: Alex -->
                    <LinearLayout
                        android:id="@+id/chip_member_alex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_avatar_placeholder"
                                android:backgroundTint="#D8E2FF" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="A"
                                android:textColor="@color/primary"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Alex"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Member 2: Sam -->
                    <LinearLayout
                        android:id="@+id/chip_member_sam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_avatar_placeholder"
                                android:backgroundTint="#E8DEF8" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="S"
                                android:textColor="#6750A4"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Sam"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Member 3: Jordan (SELECTED) -->
                    <LinearLayout
                        android:id="@+id/chip_member_jordan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp">

                        <FrameLayout
                            android:layout_width="60dp"
                            android:layout_height="60dp">
                            <!-- Outer border circle -->
                            <View
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_avatar_placeholder"
                                android:backgroundTint="@color/primary_container" />
                            <!-- Inner content circle -->
                            <View
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_avatar_placeholder"
                                android:backgroundTint="@color/surface_container_lowest" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="J"
                                android:textColor="@color/primary"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-bold" />
                            <!-- Checkmark Badge on top-right -->
                            <FrameLayout
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_avatar_placeholder"
                                android:backgroundTint="@color/primary"
                                android:padding="2dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_check"
                                    app:tint="@color/on_primary" />
                            </FrameLayout>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-bold"
                            android:text="Jordan"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Member 4: Taylor -->
                    <LinearLayout
                        android:id="@+id/chip_member_taylor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_avatar_placeholder"
                                android:backgroundTint="#FAD8FD" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="T"
                                android:textColor="#B3261E"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Taylor"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Deadline Toggle Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/on_surface_variant" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Add deadline"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_deadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- Date Picker Row -->
            <HorizontalScrollView
                android:id="@+id/scroll_date_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Date 1: Oct 15 -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_date_card_inactive"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Oct"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-bold"
                            android:text="15"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif"
                            android:text="Tue"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Date 2: Oct 16 (SELECTED) -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_date_card_active"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Oct"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-bold"
                            android:text="16"
                            android:textColor="@color/primary"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif"
                            android:text="Wed"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Date 3: Oct 17 -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_date_card_inactive"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Oct"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-bold"
                            android:text="17"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif"
                            android:text="Thu"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Date 4: Oct 18 -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_date_card_inactive"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:alpha="0.5">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Oct"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-bold"
                            android:text="18"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif"
                            android:text="Fri"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Notes Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="Notes"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/input_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/selector_input_field"
                android:hint="Add any details about this task..."
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:padding="16dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline"
                android:textSize="14sp"
                android:layout_marginBottom="32dp" />

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btn_save_task"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@color/primary"
                android:text="Save Task"
                android:textColor="@color/on_primary"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btn_delete_task"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Delete Task"
                android:textColor="@color/error"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
