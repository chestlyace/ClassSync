<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/notifications_app_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="1dp">

        <!-- Mini profile avatar placeholder -->
        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_avatar_placeholder"
            android:backgroundTint="@color/outline_variant"
            android:padding="1dp">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_placeholder"
                android:backgroundTint="@color/surface_container_lowest">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="C"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/app_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-bold"
            android:text="ClassSync"
            android:textColor="@color/primary"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:src="@drawable/ic_settings"
            app:tint="@color/on_surface_variant" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline_variant" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Title & Mark as read row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-bold"
                    android:text="Notifications"
                    android:textColor="@color/on_surface"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/btn_mark_all_read"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:text="Mark all as read"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Segmented Filter Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_segmented_control"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <!-- Tab All -->
                    <TextView
                        android:id="@+id/tab_all"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_segmented_active"
                        android:gravity="center"
                        android:text="All"
                        android:textColor="@color/primary"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="1dp" />

                    <!-- Tab Deadlines -->
                    <TextView
                        android:id="@+id/tab_deadlines"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_segmented_button_inactive"
                        android:gravity="center"
                        android:text="Deadlines"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Tab Tasks -->
                    <TextView
                        android:id="@+id/tab_tasks"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_segmented_button_inactive"
                        android:gravity="center"
                        android:text="Tasks"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </LinearLayout>

            <!-- Notifications List -->
            <LinearLayout
                android:id="@+id/notifications_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row 1: Unread Deadline -->
                <LinearLayout
                    android:id="@+id/row_deadline_unread"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/surface_container_low"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Unread left accent line -->
                    <View
                        android:id="@+id/accent_unread_1"
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_placeholder"
                            android:backgroundTint="@color/error_container">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_schedule"
                                app:tint="@color/error" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-bold"
                                android:text="Draft Introduction is due soon"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:text="Research Synthesis Report • Group Zeta"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="2m ago"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:layout_gravity="top" />

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/sep_1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant" />

                <!-- Row 2: Unread New Assignment -->
                <LinearLayout
                    android:id="@+id/row_assignment_unread"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/surface_container_low"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Unread left accent line -->
                    <View
                        android:id="@+id/accent_unread_2"
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:id="@+id/icon_bg_assignment"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_placeholder"
                            android:backgroundTint="@color/primary_fixed">

                            <ImageView
                                android:id="@+id/icon_assignment"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_notifications"
                                app:tint="@color/primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-bold"
                                android:text="New assignment posted in UX Research"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:text="Module 4: Heuristic Evaluation"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="1h ago"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:layout_gravity="top" />

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/sep_2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant" />

                <!-- Row 3: Read Task Completion -->
                <LinearLayout
                    android:id="@+id/row_task_read"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/surface_container_lowest"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_placeholder"
                            android:backgroundTint="@color/secondary_container">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check"
                                app:tint="@color/secondary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-bold"
                                android:text="Alex completed 'Literature Review'"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:text="Human-Computer Interaction • Project Alpha"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="3h ago"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:layout_gravity="top" />

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/sep_3"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant" />

                <!-- Row 4: Read Deadline -->
                <LinearLayout
                    android:id="@+id/row_deadline_read"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/surface_container_lowest"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_placeholder"
                            android:backgroundTint="@color/error_container"
                            android:alpha="0.6">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_schedule"
                                app:tint="@color/error" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="Assignment due in 2 hours"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:text="Calculus III • Problem Set 8"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="5h ago"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:layout_gravity="top" />

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/sep_4"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant" />

                <!-- Row 5: Read Task Completion -->
                <LinearLayout
                    android:id="@+id/row_task_read_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/surface_container_lowest"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_placeholder"
                            android:backgroundTint="@color/secondary_container"
                            android:alpha="0.6">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check"
                                app:tint="@color/secondary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="Team task 'Environment Setup' marked complete"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:text="Cloud Computing • Lab 4"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="Yesterday"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:layout_gravity="top" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Empty State Container -->
            <LinearLayout
                android:id="@+id/empty_state_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:paddingVertical="60dp"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_avatar_placeholder"
                    android:backgroundTint="@color/surface_container"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/outline"
                        android:alpha="0.5" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:text="You're all caught up."
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="No new alerts or deadlines at the moment. Enjoy your focused study time!"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
