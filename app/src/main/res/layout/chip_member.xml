<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:layout_marginEnd="16dp"
    tools:ignore="MissingDefaultResource">

    <FrameLayout
        android:id="@+id/chip_avatar_container"
        android:layout_width="56dp"
        android:layout_height="56dp">

        <View
            android:id="@+id/chip_avatar_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar_placeholder" />

        <TextView
            android:id="@+id/chip_avatar_initial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-medium"
            android:textSize="20sp"
            tools:text="A"
            tools:textColor="@color/primary" />

        <FrameLayout
            android:id="@+id/chip_checkmark"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_avatar_placeholder"
            android:backgroundTint="@color/primary"
            android:padding="2dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_check"
                android:contentDescription="Selected" />
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/chip_member_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/on_surface_variant"
        android:textSize="12sp"
        tools:text="Alex" />

</LinearLayout>
