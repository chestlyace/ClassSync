<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top AppBar -->
    <LinearLayout
        android:id="@+id/top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="1dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/on_surface_variant" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="Research Synthesis Report"
                android:textColor="@color/on_surface"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="Choose a group or start your own."
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp">
            <ImageView
                android:id="@+id/img_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_avatar_placeholder"
                android:background="@drawable/bg_avatar_stroke" />
        </FrameLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="56dp"
        android:background="@color/outline_variant" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="57dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Create Group Card -->
            <LinearLayout
                android:id="@+id/btn_create_group"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_dashed_border"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_primary_light"
                    android:backgroundTint="@color/primary_fixed"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_add"
                        app:tint="@color/primary" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:text="Start a new group"
                    android:textColor="@color/primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-bold"
                android:text="Open groups (3)"
                android:textColor="@color/on_surface"
                android:textSize="16sp" />

            <!-- Group Card 1: Delta -->
            <LinearLayout
                android:id="@+id/group_card_delta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_group_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:text="Group Delta"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Avatar Stack -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="32dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/bg_avatar_placeholder"
                                android:background="@drawable/bg_avatar_stroke" />

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="20dp"
                                android:src="@drawable/bg_avatar_placeholder"
                                android:background="@drawable/bg_avatar_stroke" />

                            <!-- +2 Badge -->
                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="40dp"
                                android:background="@drawable/bg_avatar_stroke"
                                android:backgroundTint="@color/surface_container_high"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:text="+2"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="2/4 members"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_join_alpha"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/primary_container"
                    android:fontFamily="sans-serif-medium"
                    android:text="Join"
                    android:textColor="@color/on_primary"
                    android:textSize="14sp"
                    app:cornerRadius="24dp" />
            </LinearLayout>

            <!-- Group Card 2: Epsilon (Full/Disabled) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_group_card"
                android:backgroundTint="@color/surface_container_low"
                android:alpha="0.8"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:text="Group Epsilon"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Avatar Stack -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="32dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/bg_avatar_placeholder"
                                android:background="@drawable/bg_avatar_stroke" />

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="20dp"
                                android:src="@drawable/bg_avatar_placeholder"
                                android:background="@drawable/bg_avatar_stroke" />

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="40dp"
                                android:src="@drawable/bg_avatar_placeholder"
                                android:background="@drawable/bg_avatar_stroke" />

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="60dp"
                                android:src="@drawable/bg_avatar_placeholder"
                                android:background="@drawable/bg_avatar_stroke" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="4/4 members"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_disabled"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:text="Full"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Group Card 3: Zeta (Joined) -->
            <FrameLayout
                android:id="@+id/group_card_zeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_secondary_border"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-bold"
                            android:text="Group Zeta"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- Avatar Stack -->
                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="32dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/bg_avatar_placeholder"
                                    android:background="@drawable/bg_avatar_stroke" />

                                <!-- +3 Badge -->
                                <TextView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_marginStart="20dp"
                                    android:background="@drawable/bg_avatar_stroke"
                                    android:backgroundTint="@color/surface_container_high"
                                    android:fontFamily="sans-serif-medium"
                                    android:gravity="center"
                                    android:text="+3"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="12sp" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="1/4 members"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button_secondary_container"
                        android:fontFamily="sans-serif-bold"
                        android:gravity="center"
                        android:paddingHorizontal="24dp"
                        android:text="Joined"
                        android:textColor="@color/on_secondary_container"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Top Right Badge "My Group" -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_badge_top_right"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:layout_margin="2dp"> <!-- Margin to stay within border -->

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/on_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="sans-serif-bold"
                        android:text="MY GROUP"
                        android:textColor="@color/on_secondary"
                        android:textSize="10sp" />
                </LinearLayout>

            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
